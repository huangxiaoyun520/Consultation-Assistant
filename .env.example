PORT=4000
HOST=0.0.0.0
DATABASE_PATH=./data/wenzhen.sqlite
CLIENT_ORIGIN=http://localhost:5173

# Required for AI generation. Without an API key, AI endpoints return an error.
# DeepSeek is OpenAI Chat Completions compatible.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# Alternative OpenAI-compatible provider variables. These take precedence when set.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
